{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "lib": ["ES2020", "DOM"],
    "jsx": "preserve",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/engine/**/*.ts",
    "src/components/**/*.tsx",
    "src/types-check/**/*.d.ts"
  ],
  "exclude": []
}
