{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "lib": ["ES2020", "DOM"],
    "types": []
  },
  "include": [
    "src/generation/**/*.ts"
  ],
  "exclude": []
}
