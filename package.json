{
  "name": "city-sim",
  "version": "1.0.0",
  "private": true,
  "description": "A deterministic, framework-agnostic city simulation engine with a React UI overlay.",
  "license": "MIT",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "analyze": "ANALYZE=1 node scripts/bundle-analyzer.mjs --max-mb 2",
    "analyze:ci": "node scripts/bundle-analyzer.mjs --max-mb 2",
    "test:unit": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test": "jest --config jest.config.cjs",
    "bench": "node scripts/bundle-analyzer.mjs --max-mb 2",
    "tag-v1": "git tag -a v1.0.0 -m \"v1.0.0\""
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
